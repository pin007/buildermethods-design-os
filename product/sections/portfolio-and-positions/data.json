{
  "_meta": {
    "models": {
      "brokers": "A connected trading platform (Interactive Brokers for stocks/options, Binance for crypto). Same brokers used across Trading Core and Portfolio & Positions.",
      "instruments": "Tradable assets with real-time price data. Extended from Trading Core with additional instruments used in watchlists.",
      "portfolios": "Named collections of positions and cash. Each portfolio has summary stats, an equity curve for charting, and allocation breakdowns.",
      "positions": "Open holdings within a portfolio, each with FIFO cost lots, tax status, and real-time P&L calculations.",
      "costLots": "Individual FIFO purchase lots within a position. Each lot tracks original quantity, remaining quantity, per-unit cost, and acquisition date for tax purposes.",
      "watchlists": "Named lists of instruments a user is monitoring, with items that include notes and optional price alerts.",
      "dividends": "Income events from held positions. Records gross amount, withholding tax, ex-date, pay-date, and CZK conversion for Czech tax reporting.",
      "dividendSummaries": "Pre-computed income totals grouped by period (monthly, quarterly, annual).",
      "upcomingDividends": "Projected dividend payments based on upcoming ex-dates for currently held positions.",
      "yieldMetrics": "Dividend yield calculations per position: yield on cost vs current yield, and annualized income.",
      "benchmarkComparison": "Portfolio performance vs a benchmark index (e.g., SPY) using time-weighted returns.",
      "marginInfo": "Margin usage, buying power, and margin call risk for portfolios with leverage enabled."
    },
    "relationships": [
      "Each Portfolio contains many Positions and CashBalances across one or more Brokers",
      "Each Position contains one or more CostLots representing FIFO purchase lots",
      "Each Position belongs to a Portfolio, a Broker, and an Instrument",
      "Each Watchlist contains many WatchlistItems, each targeting an Instrument",
      "Each Dividend belongs to a Position and records income from that holding",
      "BenchmarkComparison is computed per Portfolio for a selected benchmark and time period",
      "MarginInfo is computed per Portfolio from broker-reported margin data",
      "Equity curve and allocation data are computed per Portfolio and aggregated across all Portfolios for the overview"
    ]
  },
