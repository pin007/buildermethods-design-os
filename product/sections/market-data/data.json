{
  "_meta": {
    "models": {
      "pipelineStats": "Aggregated health metrics for the entire market data pipeline. Shown as stat cards on the overview screen.",
      "dataSources": "A connected market data vendor such as Yahoo Finance, Interactive Brokers, or Binance. Each source has its own connection status, fetch schedule, error rate, and list of tracked instruments.",
      "instrumentSubscriptions": "An instrument being tracked by a specific data source. Shows what data is being collected, the date range covered, which intervals are tracked, and how fresh the data is.",
      "fetchOperations": "A record of a single data fetch operation — scheduled, manual, backfill, or retry. Includes how many data points were fetched, how long it took, and whether it succeeded or failed.",
      "backfillTasks": "An active or completed backfill job that fills in missing historical data for a specific instrument, date range, and interval. Tracks progress percentage and estimated time remaining.",
      "corporateActions": "A detected corporate action such as a stock split, dividend, or ticker symbol change. Includes the detection date, adjustment status, and which data records were affected.",
      "qualityAlerts": "A data quality issue flagged by automated validation — outliers, gap fills, OHLCV relationship violations, or stale data. Severity ranges from info to critical. Alerts can be acknowledged after review."
    },
    "relationships": [
      "Each DataSource tracks many InstrumentSubscriptions (the instruments it fetches data for)",
      "Each DataSource logs many FetchOperations (its fetch history)",
      "BackfillTasks belong to a DataSource and target a specific InstrumentSubscription",
      "CorporateActions are detected from a DataSource and affect an Instrument's historical MarketData",
      "QualityAlerts are raised against a specific Instrument and DataSource combination",
      "InstrumentSubscriptions reference the global Instrument entity by symbol and ID"
    ]
  },

