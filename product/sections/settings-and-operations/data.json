{
  "_meta": {
    "models": {
      "settingsCategories": "The 10 settings category cards shown on the overview page. Each card has an icon, name, status summary, and optional warning badge.",
      "brokerGateways": "Connection configurations for trading platforms (Interactive Brokers and Binance). Includes encrypted credentials, connection parameters, and live status information like latency and heartbeat.",
      "dataSources": "Market data providers that feed price and volume data into the platform. Each source can be enabled/disabled and has a priority order for fallback.",
      "retentionTiers": "Data storage tiers that control how long market data is kept at different granularities — hot (recent, fast access), warm (older, compressed), and cold (archive).",
      "trackedInstruments": "Instruments actively being tracked for market data collection. The pipeline fetches data for these symbols from enabled data sources.",
      "portfolioSettings": "Global portfolio configuration including base currency, supported currencies for multi-currency portfolios, benchmark comparison, and margin alert thresholds.",
      "riskSettings": "Risk management limits that control maximum exposure. Each setting has a current value, default value, min/max bounds, and a unit (percent or ratio).",
      "taxSettings": "Czech tax reporting configuration including FIFO method, tax rates, the 3-year exemption rule, CNB exchange rate sync, and report generation settings.",
      "strategySettings": "Default parameters for the strategy engine and backtesting framework, including evaluation frequency, risk-per-trade defaults, and simulation settings.",
      "intelligenceSettings": "Configuration for AI-powered market intelligence — guru/whale tracking providers, market analyst research schedules, confidence thresholds, and scoring weights.",
      "journalSettings": "Trade journal configuration controlling whether pre/post trade notes are required, scoring dimensions for trade evaluation, behavioral pattern detection, and review schedules.",
      "notificationChannels": "Delivery channels for alerts and notifications. Each channel has its own configuration (credentials, endpoints) and can be individually enabled or disabled.",
      "notificationPreferences": "Global notification preferences including quiet hours, severity thresholds, rate limits, and a per-alert-type subscription matrix mapping alert types to channels.",
      "calendarDisplaySettings": "Trading calendar data providers, refresh schedules, alert timing before events, and display preferences like timezone and theme."
    },
    "relationships": [
      "Settings Categories link to their respective detail pages (one card per category)",
      "Broker Gateways reference the Broker entity from the global data model",
      "Tracked Instruments reference the Instrument entity from the global data model",
      "Data Sources feed into the Market Data pipeline and are ordered by priority",
      "Notification Channels are referenced by the subscription matrix in Notification Preferences",
      "Risk Settings enforce limits on Orders and Positions from the global data model",
      "Tax Settings control how CostLots, LotMatches, and Dividends are calculated for CZK reporting"
    ]
  },

