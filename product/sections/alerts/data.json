  "inhibitionRules": [
    {
      "id": "inhibit-001",
      "name": "Broker down → suppress trading warnings",
      "description": "When a broker is disconnected (critical), suppress all trading-related warnings for that broker to reduce noise.",
      "sourceMatch": { "name": "BrokerDisconnected", "severity": "critical" },
      "targetMatch": { "source": "broker", "severity": "warning" },
      "equal": ["broker"],
      "enabled": true,
      "suppressedCount": 0
    },
    {
      "id": "inhibit-002",
      "name": "Pipeline down → suppress stale data",
      "description": "When the market data pipeline is down, suppress individual stale data warnings since they are a symptom.",
      "sourceMatch": { "name": "DataProviderOutage", "severity": "critical" },
      "targetMatch": { "name": "StaleMarketData" },
      "equal": ["provider"],
      "enabled": true,
      "suppressedCount": 0
    },
    {
      "id": "inhibit-003",
      "name": "System critical → suppress strategy alerts",
      "description": "When system health is critical, suppress all strategy performance alerts since performance data may be unreliable.",
      "sourceMatch": { "source": "system", "severity": "critical" },
      "targetMatch": { "source": "strategy" },
