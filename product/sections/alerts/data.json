    "models": {
      "alerts": "An alert is a notification from a component about an issue that requires attention. Each alert has severity, source, and labels for matching.",
      "silences": "A silence temporarily mutes alerts matching specific label criteria. Used during maintenance windows or known issues.",
      "routes": "A route defines how alerts are delivered to the user — through which channel and with what grouping and timing.",
      "inhibitionRules": "An inhibition rule suppresses certain alerts when more severe related alerts are already firing, reducing noise.",
      "alertStats": "Summary statistics about the current state of the alert system."
    },
    "relationships": [
      "Alerts can be silenced by Silences (matched by labels)",
      "Alerts are delivered via Routes (matched by labels)",
      "Alerts can be suppressed by Inhibition Rules (source/target label matching)",
      "Each Alert belongs to a source component (broker, market-data, risk, strategy, portfolio, system)"
    ]
