      "orders": "The core entity for Trading Core. Represents a request to buy or sell an instrument. Spans 12 status states and supports bracket orders with OCO (One-Cancels-Other) behavior.",
      "orderEvents": "Immutable records of state changes in an order's lifecycle. Displayed as a collapsible event timeline in the order detail view.",
      "trades": "Executed transactions created when orders fill. Shown in the recent activity list on the dashboard and in order detail.",
      "recommendations": "AI-generated trade suggestions shown in the approval card. Include confidence scores, reasoning, and target prices.",
      "recentActivity": "Pre-computed list of the last 5 events for the dashboard activity feed."
    },
    "relationships": [
      "Each Portfolio is connected to one or more Brokers and holds positions in Instruments",
      "Each Order belongs to a Portfolio, targets an Instrument, and is routed through a Broker",
      "Each Order logs one or more OrderEvents forming its audit timeline",
      "Each Trade is created when an Order fills (partially or fully)",
      "Bracket orders form a group: one parent Order with child Orders (stop-loss and/or take-profit) linked by bracketGroupId",
      "A Recommendation may become an Order when approved (linked by recommendationId on the Order)"
    ]
  },

